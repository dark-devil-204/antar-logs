---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import type { CollectionEntry } from "astro:content";
import readingTime from "reading-time";
const allPosts = (await getCollection("blog")) as CollectionEntry<"blog">[];
const sortedPosts = [...allPosts].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const allTags = Array.from(
  new Set(
    sortedPosts
      .flatMap((post) => post.data.tags ?? [])
      .map((tag) => tag.trim()),
  ),
).sort((a, b) => a.localeCompare(b));
---

<BaseLayout
  title="Home | Antar Logs"
  description="Technical notes, experiments, and project write-ups by Antar. Search posts and filter by topic tags."
>
  <p>
    I build systems, languages, and backend infra. This is where i log my
    learnings, experiments, and projects.
  </p>

  <section aria-labelledby="blog-posts-heading">
    <h2 id="blog-posts-heading">Blog posts</h2>
    <p>sorted by date, newest on top</p>

    <form id="post-filters" role="search" aria-label="Search and filter posts">
      <label for="post-search">Search posts</label>
      <input
        type="search"
        id="post-search"
        name="q"
        placeholder="Search by title, summary, or tag"
      />

      <label for="tag-filter">Filter by tag</label>
      <select id="tag-filter" name="tag">
        <option value="">All tags</option>
        {allTags.map((tag) => <option value={tag}>{tag}</option>)}
      </select>

      <button id="clear-filters" type="button">Clear filters</button>
      <p id="results-count" aria-live="polite">
        Showing {sortedPosts.length} posts
      </p>
    </form>

    <ul id="post-list">
      {
        sortedPosts.map((post) => {
          const stats = readingTime(post.body as string);
          const tags = post.data.tags ?? [];

          return (
            <li
              data-title={post.data.title.toLowerCase()}
              data-description={post.data.description.toLowerCase()}
              data-tags={tags.join(" ").toLowerCase()}
            >
              <article>
                <header>
                  <h3>
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </h3>
                  <p>
                    <small>
                      <time datetime={post.data.date.toISOString()}>
                        {post.data.date.toLocaleDateString("en-US", {
                          year: "numeric",
                          month: "long",
                          day: "numeric",
                        })}
                      </time>
                      {" · "}
                      {Math.ceil(stats.minutes)} min read
                    </small>
                  </p>
                </header>

                <p>{post.data.description}</p>

                {tags.length > 0 && (
                  <p>
                    <small>
                      Tags:{" "}
                      {tags.map((tag, index) => (
                        <>
                          <a href={`/tags/${encodeURIComponent(tag)}`}>
                            #{tag}
                          </a>
                          {index < tags.length - 1 ? " " : ""}
                        </>
                      ))}
                    </small>
                  </p>
                )}
              </article>
            </li>
          );
        })
      }
    </ul>

    <p id="no-results" hidden>No posts match your search and filter.</p>
  </section>

  <script>
    const searchInput = document.querySelector("#post-search");
    const tagSelect = document.querySelector("#tag-filter");
    const clearButton = document.querySelector("#clear-filters");
    const resultCount = document.querySelector("#results-count");
    const noResults = document.querySelector("#no-results");
    const items = Array.from(document.querySelectorAll("#post-list > li"));

    if (searchInput && tagSelect && clearButton && resultCount && noResults) {
      const updateFilters = () => {
        const searchTerm = searchInput.value.trim().toLowerCase();
        const selectedTag = tagSelect.value.trim().toLowerCase();
        let visibleCount = 0;

        items.forEach((item) => {
          const title = item.dataset.title ?? "";
          const description = item.dataset.description ?? "";
          const tags = item.dataset.tags ?? "";

          const matchesSearch =
            searchTerm.length === 0 ||
            title.includes(searchTerm) ||
            description.includes(searchTerm) ||
            tags.includes(searchTerm);
          const matchesTag =
            selectedTag.length === 0 || tags.includes(selectedTag);
          const show = matchesSearch && matchesTag;

          item.hidden = !show;
          if (show) visibleCount += 1;
        });

        resultCount.textContent = `Showing ${visibleCount} post${visibleCount === 1 ? "" : "s"}`;
        noResults.hidden = visibleCount !== 0;
      };

      searchInput.addEventListener("input", updateFilters);
      tagSelect.addEventListener("change", updateFilters);
      clearButton.addEventListener("click", () => {
        searchInput.value = "";
        tagSelect.value = "";
        updateFilters();
      });
    }
  </script>
</BaseLayout>
